{
  "$schema": "/etc/xdg/swaync/configSchema.json",

  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "cssPriority": "user",

  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 8,
  "control-center-margin-left": 8,

  "notification-2fa-action": true,
  "notification-inline-replies": true,
  "notification-icon-size": 48,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "notification-window-width": 380,

  "timeout": 5,
  "timeout-low": 5,
  "timeout-critical": 0,

  "fit-to-screen": true,
  "control-center-width": 400,
  "control-center-height": 700,

  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,

  "widgets": [
    "title",
    "buttons-grid",
    "dnd",
    "mpris",
    "volume",
    "backlight",
    "notifications"
  ],

  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "󰎟  Clear All"
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰖩",
          "type": "toggle",
          "active": true,
          "command": "sh -c 'nmcli radio wifi | grep -q enabled && nmcli radio wifi off || nmcli radio wifi on'",
          "update-command": "sh -c 'nmcli radio wifi | grep -q enabled && echo true || echo false'"
        },
        {
          "label": "󰂯",
          "type": "toggle",
          "active": true,
          "command": "sh -c 'bluetoothctl show | grep -q \"Powered: yes\" && bluetoothctl power off || bluetoothctl power on'",
          "update-command": "sh -c 'bluetoothctl show | grep -q \"Powered: yes\" && echo true || echo false'"
        },
        {
          "label": "󰀝",
          "type": "toggle",
          "active": false,
          "command": "sh -c 'rfkill list | grep -q \"Soft blocked: yes\" && rfkill unblock all || rfkill block all'",
          "update-command": "sh -c 'rfkill list | grep -q \"Soft blocked: yes\" && echo true || echo false'"
        },
        {
          "label": "󰖩 ",
          "type": "button",
          "command": "kitty -e nmtui"
        },
        {
          "label": "󰂲 ",
          "type": "button",
          "command": "kitty -e bluetoothctl"
        },
        {
          "label": "󰕾 ",
          "type": "button",
          "command": "pavucontrol"
        }
      ]
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-size": 88,
      "image-radius": 12
    },
    "volume": {
      "label": "󰕾",
      "show-per-app": true
    },
    "backlight": {
      "label": "󰃟",
      "device": "intel_backlight"
    }
  }
}
