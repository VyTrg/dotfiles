{
  "cli_default_open_behavior": "existing_window",
  "diff_view_style": "split",
  "project_panel": {
    "dock": "left",
  },
  "format_on_save": "on",
  "bottom_dock_layout": "contained",
  "helix_mode": true,
  "icon_theme": "Zed (Default)",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Ayu Dark",
    "dark": "Ayu Mirage",
  },

  "lsp": {
    "tinymist": {
      "initialization_options": {
        "typstMain": "main.typ",
        "preview": {
          "background": {
            "enabled": true,
          },
        },
      },

      "settings": {
        "exportPdf": "onSave",
        "outputPath": "$root/main",
        "formatterMode": "typstyle",
      },
    },
  },
}
